# Next.js / app runtime
PORT=8080
LEAD_SENDER_NAME=Ontario Accident Review
LEAD_ALERT_EMAIL_TO=youngmlse@yahoo.com

# Supabase persistence (required for intake submissions)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key
# Optional: override only if you use a different table name.
SUPABASE_INTAKE_TABLE=intake_submissions

# Legacy dashboard env vars below are only relevant if you still run the old local prototype.
# The active Next.js intake endpoint does not use these values.

# Dashboard access
DASHBOARD_ALLOW_REMOTE=false
DASHBOARD_PASSWORD=change-this-before-use
DASHBOARD_SESSION_TTL_HOURS=12

# Email delivery (legacy prototype / future alert plumbing)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=alerts@example.com
SMTP_PASS=replace-with-real-password-or-app-password
SMTP_FROM_EMAIL=alerts@example.com
SMTP_FROM_NAME=Ontario Accident Review
SMTP_EHLO_NAME=localhost

# Telegram delivery (legacy prototype / future alert plumbing)
TELEGRAM_BOT_TOKEN=123456789:replace-with-real-bot-token
TELEGRAM_CHAT_ID=123456789
# TELEGRAM_API_BASE=https://api.telegram.org
